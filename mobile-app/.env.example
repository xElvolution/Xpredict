# Privy (same App ID as the web app — share identity across web + mobile)
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Web app's API base URL (for /api/coach and /api/markets-meta)
# Use your Vercel deployment URL in prod, or http://localhost:3000 with `expo start --tunnel` for dev
EXPO_PUBLIC_API_BASE_URL=https://xpredict-nu.vercel.app

# Onchain addresses (same as web app — copy from main .env)
EXPO_PUBLIC_FACTORY_ADDRESS=
EXPO_PUBLIC_USDC_ADDRESS=
