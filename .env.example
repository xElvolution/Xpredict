# =================================================================
# XPredict environment variables
# Copy to .env.local for the Next.js app, .env for the agents.
# =================================================================

# ----- Chain (X Layer Testnet) -----
NEXT_PUBLIC_CHAIN_ID=195
NEXT_PUBLIC_RPC_URL=https://testrpc.xlayer.tech
NEXT_PUBLIC_EXPLORER_URL=https://www.oklink.com/xlayer-test

# ----- Privy (frontend + agents) -----
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Privy server wallet IDs (Settings → User Management → Server Wallets)
PRIVY_CURATOR_WALLET_ID=your-curator-server-wallet-id
PRIVY_RESOLVER_WALLET_ID=your-resolver-server-wallet-id

# Privy server wallet addresses (0x... from the same dashboard screen)
# CURATOR_ADDRESS  — deploy script only (whitelists the curator agent)
# RESOLVER_ADDRESS — deploy script + stays in .env (Curator agent passes it when creating markets)
CURATOR_ADDRESS=
RESOLVER_ADDRESS=

# ----- Contract addresses (from Foundry deploy output) -----
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_FAUCET_ADDRESS=

# ----- AI / search APIs -----
OPENAI_API_KEY=
TAVILY_API_KEY=
# Optional later: PERPLEXITY_API_KEY (swap in agents/lib/tavily.ts)

# ----- Database (VPS Postgres) -----
DATABASE_URL=postgres://xpredict:password@localhost:5432/xpredict

# ----- Agent SDK API (Curator reviews proposals from SDK queue) -----
# Random secret shared by Curator cron + PATCH /api/v1/proposals/:id
CURATOR_INTERNAL_SECRET=

# ----- Foundry deploy (shell env when running forge script; do not commit) -----
DEPLOYER_PRIVATE_KEY=
# TREASURY_ADDRESS — NOT an agent wallet; any address you control where protocol fees go
# (your deployer wallet is fine for the hackathon). Deploy script only.
TREASURY_ADDRESS=
